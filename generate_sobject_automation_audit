def fmt_date(iso_str):
    from datetime import datetime
    if not iso_str:
        return ""
    try:
        return datetime.fromisoformat(iso_str.replace("Z", "+00:00")).strftime("%Y-%m-%d")
    except Exception:
        return iso_str[:10]


def fetch_entity_id():
    cached = load_cache(CACHE_DIR, f"entity_id_{OBJECT_NAME}")
    if cached is not None:
        return cached.get("id")

    records = run_soql(
        f"SELECT Id, DurableId, QualifiedApiName FROM EntityDefinition "
        f"WHERE QualifiedApiName = '{OBJECT_NAME}'",
        org_alias=ORG_ALIAS,
        tooling=True,
    )
    # EntityDefinition.Id is always '000000000000000AAA' (Salesforce virtual table quirk).
    # DurableId is the real identifier (e.g. '01Ixxxx...' for custom objects).
    entity_id = None
    if records:
        durable = records[0].get("DurableId") or ""
        raw_id  = records[0].get("Id") or ""
        entity_id = durable if (durable and durable != "000000000000000AAA") else (
                    raw_id  if (raw_id  and raw_id  != "000000000000000AAA") else None)
    save_cache(CACHE_DIR, f"entity_id_{OBJECT_NAME}", {"id": entity_id})
    return entity_id


def fetch_field_definitions():
    cached = load_cache(CACHE_DIR, f"fd_{OBJECT_NAME}")
    if cached is not None:
        return cached

    print(f"  [fetch] FieldDefinition for {OBJECT_NAME} ...")
    records = run_soql(
        f"SELECT QualifiedApiName, Label, DataType, IsNillable, "
        f"IsCalculated, IsApiFilterable, LastModifiedDate "
        f"FROM FieldDefinition "
        f"WHERE EntityDefinition.QualifiedApiName = '{OBJECT_NAME}' "
        f"ORDER BY Label ASC LIMIT 1000",
        org_alias=ORG_ALIAS,
        tooling=True,
    )

    result = {}
    for r in records:
        api = r["QualifiedApiName"]
        result[api] = {
            "label":            r.get("Label") or api,
            "dataType":         r.get("DataType") or "Unknown",
            "isNillable":       r.get("IsNillable", True),
            "isCalculated":     r.get("IsCalculated", False),
            "isApiFilterable":  r.get("IsApiFilterable", False),
            "lastModifiedDate": r.get("LastModifiedDate", ""),
        }

    save_cache(CACHE_DIR, f"fd_{OBJECT_NAME}", result)
    print(f"         {len(result)} fields")
    return result


def fetch_custom_field_dates():
    """Fetch CreatedDate and LastModifiedDate for custom fields via Tooling API."""
    cached = load_cache(CACHE_DIR, f"cf_{OBJECT_NAME}")
    if cached is not None:
        return cached

    print(f"  [fetch] CustomField dates for {OBJECT_NAME} ...")

    def _query(table_enum_or_id):
        return run_soql(
            f"SELECT DeveloperName, NamespacePrefix, CreatedDate, LastModifiedDate "
            f"FROM CustomField "
            f"WHERE TableEnumOrId = '{table_enum_or_id}' "
            f"LIMIT 2000",
            org_alias=ORG_ALIAS,
            tooling=True,
        )

    records = _query(OBJECT_NAME)
    if not records and OBJECT_NAME.endswith("__c"):
        entity_id = fetch_entity_id()
        if entity_id:
            records = _query(entity_id)

    result = {}
    for r in records:
        dev = r.get("DeveloperName", "")
        ns  = r.get("NamespacePrefix") or ""
        api = f"{ns}__{dev}__c" if ns else f"{dev}__c"
        result[api] = {
            "created":  fmt_date(r.get("CreatedDate", "")),
            "modified": fmt_date(r.get("LastModifiedDate", "")),
        }

    save_cache(CACHE_DIR, f"cf_{OBJECT_NAME}", result)
    print(f"         {len(result)} custom field date records")
    return result


def fetch_describe():
    cached = load_cache(CACHE_DIR, f"desc_{OBJECT_NAME}")
    if cached is not None:
        return cached

    print(f"  [fetch] sobject describe for {OBJECT_NAME} ...")
    r = subprocess.run(
        ["sf", "sobject", "describe", "-s", OBJECT_NAME, "-o", ORG_ALIAS, "--json"],
        capture_output=True, text=True, timeout=300,
    )
    if r.returncode != 0:
        print(f"  ERROR describing {OBJECT_NAME}: {r.stderr[:400]}")
        return {}

    try:
        fields = {f["name"]: f for f in json.loads(r.stdout)["result"]["fields"]}
    except (KeyError, json.JSONDecodeError) as e:
        print(f"  ERROR parsing describe for {OBJECT_NAME}: {e}")
        return {}

    save_cache(CACHE_DIR, f"desc_{OBJECT_NAME}", fields)
    print(f"         {len(fields)} fields from describe")
    return fields


def fetch_population_rates(desc_index):
    print(f"\n  [fetch] Population rates for {OBJECT_NAME} ...")

    result = run_soql(f"SELECT COUNT() FROM {OBJECT_NAME}", org_alias=ORG_ALIAS)
    if not result or not (result[0].get("expr0") if result else None):
        # COUNT() without GROUP BY returns totalSize not records
        # Try a different approach
        args = [
            "sf", "data", "query", "--query", f"SELECT COUNT() FROM {OBJECT_NAME}",
            "-o", ORG_ALIAS, "--json",
        ]
        r = subprocess.run(args, capture_output=True, text=True, timeout=300)
        try:
            total = json.loads(r.stdout).get("result", {}).get("totalSize", 0)
        except Exception:
            total = 0
    else:
        total = 0

    if not total:
        # One more attempt using COUNT(Id)
        count_records = run_soql(
            f"SELECT COUNT(Id) cnt FROM {OBJECT_NAME}",
            org_alias=ORG_ALIAS,
        )
        total = count_records[0].get("cnt", 0) if count_records else 0

    if not total:
        print("  Could not get total record count — skipping population rates.")
        return {}

    print(f"  Total {OBJECT_NAME} records: {total:,}")

    filterable = [name for name, f in desc_index.items() if f.get("filterable", False)]
    print(f"  Filterable fields to measure: {len(filterable)}")

    rates = {}
    batches = [filterable[i:i + BATCH_SIZE] for i in range(0, len(filterable), BATCH_SIZE)]

    for idx, batch in enumerate(batches, 1):
        exprs  = ", ".join(f"COUNT({f})" for f in batch)
        result = run_soql(
            f"SELECT {exprs} FROM {OBJECT_NAME}",
            org_alias=ORG_ALIAS,
        )

        if result and result[0]:
            rec = result[0]
            for i, field_name in enumerate(batch):
                count_val = rec.get(f"expr{i}") or 0
                rates[field_name] = f"{count_val / total * 100:.1f}%" if total else "N/A"
        else:
            for field_name in batch:
                single = run_soql(
                    f"SELECT COUNT({field_name}) FROM {OBJECT_NAME}",
                    org_alias=ORG_ALIAS,
                )
                if single and single[0]:
                    count_val = single[0].get("expr0") or 0
                    rates[field_name] = f"{count_val / total * 100:.1f}%" if total else "N/A"
                else:
                    rates[field_name] = "N/A"

        if idx % 5 == 0 or idx == len(batches):
            print(f"  Progress: {idx}/{len(batches)} batches done")

    return rates


def merge_field_metadata():
    """
    Combine FieldDefinition + sobject describe + CustomField dates
    into a unified field dict keyed by API name.
    """
    fd_records  = fetch_field_definitions()
    desc_index  = fetch_describe()
    cf_index    = fetch_custom_field_dates()
    pop_rates   = fetch_population_rates(desc_index)

    merged = {}
    for api, fd_rec in fd_records.items():
        desc_rec = desc_index.get(api, {})
        is_custom = api.endswith("__c")

        # Picklist values
        field_values = ""
        if desc_rec.get("type") in ("picklist", "multipicklist"):
            vals = [
                pv["label"]
                for pv in desc_rec.get("picklistValues", [])
                if pv.get("active", True)
            ]
            field_values = "; ".join(vals)

        # Behavior
        if desc_rec:
            if not desc_rec.get("createable") and not desc_rec.get("updateable"):
                behavior = "System (Read Only)"
            elif not desc_rec.get("nillable", True):
                behavior = "Required"
            else:
                behavior = "Optional"
        else:
            behavior = "Required" if not fd_rec.get("isNillable", True) else "Optional"

        # Has Default Value
        raw_default = desc_rec.get("defaultValue")
        has_default = (raw_default is not None) or bool(desc_rec.get("defaultValueFormula"))

        # Is Formula
        is_formula = bool(fd_rec.get("isCalculated") or desc_rec.get("calculated", False))

        # Is Encrypted
        is_encrypted = bool(desc_rec.get("encrypted", False))

        # Available for Reporting
        is_reportable = bool(
            fd_rec.get("isApiFilterable") or desc_rec.get("filterable", False)
        )

        # Dates
        if is_custom:
            cf = cf_index.get(api, {})
            created_date  = cf.get("created", "")
            modified_date = cf.get("modified", "") or fmt_date(fd_rec.get("lastModifiedDate", ""))
        else:
            created_date  = "N/A (Standard Field)"
            modified_date = fmt_date(fd_rec.get("lastModifiedDate", ""))

        merged[api] = {
            "label":        fd_rec.get("label") or api,
            "dataType":     fd_rec.get("dataType") or desc_rec.get("type", "Unknown"),
            "fieldValues":  field_values,
            "behavior":     behavior,
            "isCustom":     is_custom,
            "hasDefault":   has_default,
            "isFormula":    is_formula,
            "isEncrypted":  is_encrypted,
            "isReportable": is_reportable,
            "popRate":      pop_rates.get(api, "N/A"),
            "createdDate":  created_date,
            "modifiedDate": modified_date,
        }

    return merged, desc_index


