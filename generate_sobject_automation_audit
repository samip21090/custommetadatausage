def main():
    print(f"\n{'=' * 60}")
    print(f"  SObject Automation Audit")
    print(f"  Object : {OBJECT_NAME}")
    print(f"  Org    : {ORG_ALIAS}")
    print(f"  Output : {OUTPUT_XLSX}")
    print(f"  Cache  : {CACHE_DIR}")
    print(f"{'=' * 60}\n")

    os.makedirs(CACHE_DIR, exist_ok=True)

    # Authenticate
    print("Authenticating ...")
    token, inst_url = get_credentials(ORG_ALIAS)
    print(f"  Instance: {inst_url}\n")

    # 1. Field metadata
    print(f"[1/5] Field metadata ...")
    merged_fields, _ = merge_field_metadata()
    field_api_names  = list(merged_fields.keys())
    print(f"      {len(field_api_names)} total fields\n")

    # 2. Apex Trigger analysis
    print(f"[2/6] Apex Trigger analysis ...")
    trigger_analysis = analyze_triggers(field_api_names, token, inst_url)
    print(f"      {len(trigger_analysis)} fields referenced in triggers\n")

    # 3. Apex Class analysis
    print(f"[3/6] Apex Class analysis ...")
    apex_class_analysis = analyze_apex_classes(field_api_names, token, inst_url)
    print(f"      {len(apex_class_analysis)} fields referenced in apex classes\n")

    # 4. Flow analysis
    print(f"[4/6] Flow analysis ...")
    flow_analysis = analyze_flows(field_api_names, token, inst_url)
    print(f"      {len(flow_analysis)} fields referenced in flows\n")

    # 5. Validation Rule analysis
    print(f"[5/6] Validation Rule analysis ...")
    vr_analysis = analyze_validation_rules(field_api_names, token, inst_url)
    print(f"      {len(vr_analysis)} fields referenced in validation rules\n")

    # 6. Workflow Field Update analysis
    print(f"[6/6] Workflow Field Update analysis ...")
    wf_analysis = fetch_workflow_dependencies()
    print(f"      {len(wf_analysis)} fields targeted by workflow field updates\n")

    # Build rows & write Excel
    print("Building output rows ...")
    rows = build_rows(merged_fields, trigger_analysis, apex_class_analysis, flow_analysis, vr_analysis, wf_analysis)

    print("Writing Excel ...")
    write_excel(rows)

    # Summary — field-level counts
    triggered   = sum(1 for r in rows if r["Is used in Trigger (Y/N)"] == "Y")
    in_classes  = sum(1 for r in rows if r["Is used in Apex Class (Y/N)"] == "Y")
    flowed      = sum(1 for r in rows if r["Is used in Flow (Y/N)"] == "Y")
    validated   = sum(1 for r in rows if r["Is used in Validation Rule (Y/N)"] == "Y")
    set_by_auto = sum(1 for r in rows if r["Is Set by Automation (Y/N)"].startswith("Y"))

    # Summary — object-level automation counts (unique automations touching this object)
    unique_triggers = set(n for info in trigger_analysis.values()     for n in info.get("trigger_names", []))
    unique_classes  = set(n for info in apex_class_analysis.values()  for n in info.get("class_names", []))
    unique_flows    = set(n for info in flow_analysis.values()         for n in info.get("flow_names", []))
    unique_vrs      = set(vr for r in rows for vr in r["Validation Rule Name"].split("; ") if vr)
    unique_wfs      = set(n for info in wf_analysis.values()           for n in info.get("wf_names", []))

    print(f"\n{'─' * 60}")
    print(f"  {'OBJECT-LEVEL':30s}  {'FIELD-LEVEL':>10s}")
    print(f"  {'─' * 56}")
    print(f"  {'Total fields':30s}  {len(rows):>10,}")
    print(f"  {'Apex Triggers':30s}  {len(unique_triggers):>5} triggers  /  {triggered:>4} fields")
    print(f"  {'Apex Classes':30s}  {len(unique_classes):>5} classes   /  {in_classes:>4} fields")
    print(f"  {'Flows':30s}  {len(unique_flows):>5} flows     /  {flowed:>4} fields")
    print(f"  {'Validation Rules (active)':30s}  {len(unique_vrs):>5} VRs       /  {validated:>4} fields")
    wf_fields = sum(1 for r in rows if r["Workflow Rule Dependencies"])
    print(f"  {'Workflow Field Updates':30s}  {len(unique_wfs):>5} updates   /  {wf_fields:>4} fields")
    print(f"  {'─' * 56}")
    print(f"  {'Fields set by automation':30s}  {set_by_auto:>10,}")
    print(f"{'─' * 60}")


if __name__ == "__main__":
    main()
