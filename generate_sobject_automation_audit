def fetch_validation_rules(token, inst_url):
    cached = load_cache(CACHE_DIR, f"vr_{OBJECT_NAME}")
    if cached is not None:
        return cached

    print(f"  [fetch] Validation rules for {OBJECT_NAME} ...")

    # Use relationship query — avoids EntityDefinitionId altogether (EntityDefinition.Id
    # returns 000000000000000AAA for custom objects, making the ID approach unreliable).
    # Fetch ALL VRs (active + inactive) so we don't silently miss ones where the Tooling
    # API disagrees with the UI on Active status; filter to active in Python.
    records = run_soql(
        f"SELECT Id, ValidationName, Active, ErrorDisplayField "
        f"FROM ValidationRule "
        f"WHERE EntityDefinition.QualifiedApiName = '{OBJECT_NAME}' "
        f"LIMIT 200",
        org_alias=ORG_ALIAS,
        tooling=True,
    )
    all_count = len(records)
    records = [r for r in records if r.get("Active")]
    print(f"         {all_count} total, {len(records)} active")

    enriched = []
    for r in records:
        vr_id = r["Id"]
        data  = tooling_rest_get(
            f"sobjects/ValidationRule/{vr_id}?fields=Metadata", token, inst_url
        )
        formula = ""
        if data and isinstance(data.get("Metadata"), dict):
            formula = data["Metadata"].get("errorConditionFormula") or ""
        r["ErrorConditionFormula"] = formula
        enriched.append(r)

    print(f"         {len(enriched)} active validation rules — formulas fetched")

    save_cache(CACHE_DIR, f"vr_{OBJECT_NAME}", enriched)
    print(f"         done.")
    return enriched


def analyze_validation_rules(field_api_names, token, inst_url):
    """
    Returns dict: field_api_name -> {
        vr_names: [str],
        vr_formulas: [str],
    }
    """
    vr_records = fetch_validation_rules(token, inst_url)

    field_info = defaultdict(lambda: {"vr_names": [], "vr_formulas": []})

    for vr in vr_records:
        name    = vr.get("ValidationName", "")
        formula = vr.get("ErrorConditionFormula") or ""

        # Find matching fields
        for field in field_api_names:
            if re.search(rf'\b{re.escape(field)}\b', formula, re.IGNORECASE):
                info    = field_info[field]
                snippet = formula if len(formula) <= 200 else formula[:200] + "..."
                info["vr_names"].append(name)
                info["vr_formulas"].append(f"{name}: {snippet}")

    return dict(field_info)


