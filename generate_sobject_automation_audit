def fetch_apex_classes(token, inst_url):
    cached = load_cache(CACHE_DIR, f"apexclasses_{OBJECT_NAME}")
    if cached is not None:
        return cached

    print(f"  [fetch] Apex classes referencing {OBJECT_NAME} ...")

    # Step 1: Try the fast path — Body LIKE in SOQL (works for unmanaged classes only;
    # managed classes have Body='(hidden)' so they never match the LIKE filter)
    records = run_soql(
        f"SELECT Id, Name, Body FROM ApexClass "
        f"WHERE Status = 'Active' AND Body LIKE '%{OBJECT_NAME}%' "
        f"LIMIT 500",
        org_alias=ORG_ALIAS,
        tooling=True,
    )
    print(f"         {len(records)} classes matched via SOQL LIKE")

    # Step 2: Also fetch all active unmanaged classes via REST to catch any that
    # were missed (e.g. if SOQL Body LIKE silently returned 0 due to hidden bodies)
    all_unmanaged = run_soql(
        f"SELECT Id, Name FROM ApexClass "
        f"WHERE Status = 'Active' AND NamespacePrefix = null "
        f"LIMIT 500",
        org_alias=ORG_ALIAS,
        tooling=True,
    )
    already_found = {r["Id"] for r in records}
    remaining = [r for r in all_unmanaged if r["Id"] not in already_found]

    if remaining:
        print(f"         Checking {len(remaining)} additional unmanaged classes via REST ...")
        for r in remaining:
            data = tooling_rest_get(f"sobjects/ApexClass/{r['Id']}", token, inst_url)
            body = (data.get("Body") or "") if data else ""
            if body and body.strip() != "(hidden)" and OBJECT_NAME.lower() in body.lower():
                r["Body"] = body
                records.append(r)

    # Ensure every record has a Body key (SOQL results already have it)
    for r in records:
        if "Body" not in r:
            r["Body"] = ""

    save_cache(CACHE_DIR, f"apexclasses_{OBJECT_NAME}", records)
    print(f"         {len(records)} apex classes reference {OBJECT_NAME}")
    return records


def analyze_apex_classes(field_api_names, token, inst_url):
    """
    Returns dict: field_api_name -> {
        class_names: [str],
        criteria_notes: [str],
        is_set: bool,
    }
    """
    classes = fetch_apex_classes(token, inst_url)

    field_info = defaultdict(lambda: {
        "class_names":    [],
        "criteria_notes": [],
        "is_set":         False,
    })

    for cls in classes:
        name = cls.get("Name", "")
        body = cls.get("Body") or ""
        if not body or body.strip() == "(hidden)":
            continue

        fields_found = _find_fields_in_apex(body, field_api_names)

        for field in fields_found:
            info = field_info[field]
            info["class_names"].append(name)

            is_written = _field_is_written_in_apex(body, field)
            if is_written:
                info["is_set"] = True
                action = "writes"
            else:
                action = "reads"

            info["criteria_notes"].append(f"{name} (Apex Class) — {action} field")

    return dict(field_info)


