def fetch_triggers(token, inst_url):
    cached = load_cache(CACHE_DIR, f"triggers_{OBJECT_NAME}")
    if cached is not None:
        return cached

    print(f"  [fetch] Apex triggers for {OBJECT_NAME} ...")
    # Query metadata only (no Body in SELECT — Tooling SOQL Body can return '(hidden)')
    records = run_soql(
        f"SELECT Id, Name, TableEnumOrId, Status, "
        f"UsageBeforeInsert, UsageAfterInsert, "
        f"UsageBeforeUpdate, UsageAfterUpdate, "
        f"UsageBeforeDelete, UsageAfterDelete, "
        f"UsageAfterUndelete "
        f"FROM ApexTrigger "
        f"WHERE TableEnumOrId = '{OBJECT_NAME}' AND Status = 'Active' "
        f"LIMIT 100",
        org_alias=ORG_ALIAS,
        tooling=True,
    )

    # Fetch body via REST per trigger — REST returns actual body even when SOQL shows '(hidden)'
    print(f"         {len(records)} triggers — fetching bodies via REST ...")
    enriched = []
    for r in records:
        data = tooling_rest_get(f"sobjects/ApexTrigger/{r['Id']}", token, inst_url)
        r["Body"] = (data.get("Body") or "") if data else ""
        enriched.append(r)

    save_cache(CACHE_DIR, f"triggers_{OBJECT_NAME}", enriched)
    print(f"         done.")
    return enriched


def _trigger_events_str(trigger):
    events = []
    if trigger.get("UsageBeforeInsert"):  events.append("before insert")
    if trigger.get("UsageAfterInsert"):   events.append("after insert")
    if trigger.get("UsageBeforeUpdate"):  events.append("before update")
    if trigger.get("UsageAfterUpdate"):   events.append("after update")
    if trigger.get("UsageBeforeDelete"):  events.append("before delete")
    if trigger.get("UsageAfterDelete"):   events.append("after delete")
    if trigger.get("UsageAfterUndelete"): events.append("after undelete")
    return ", ".join(events) if events else "unknown events"


def _find_fields_in_apex(body, field_api_names):
    found = set()
    for field in field_api_names:
        pattern = re.compile(
            rf'(?:'
            rf'\.\s*{re.escape(field)}\b'
            rf'|(?:SELECT|,)\s+{re.escape(field)}\b'
            rf'|\b{re.escape(field)}\s*='
            rf')',
            re.IGNORECASE,
        )
        if pattern.search(body):
            found.add(field)
    return found


def _field_is_written_in_apex(body, field):
    set_pattern = re.compile(
        rf'\.\s*{re.escape(field)}\s*=(?!=)',
        re.IGNORECASE,
    )
    return bool(set_pattern.search(body))


def analyze_triggers(field_api_names, token, inst_url):
    """
    Returns dict: field_api_name -> {
        trigger_names: [str],
        criteria_notes: [str],
        is_set: bool,
    }
    """
    triggers = fetch_triggers(token, inst_url)

    field_info = defaultdict(lambda: {
        "trigger_names":  [],
        "criteria_notes": [],
        "is_set":         False,
    })

    for trigger in triggers:
        name      = trigger.get("Name", "")
        body      = trigger.get("Body") or ""
        if not body or body.strip() == "(hidden)":
            continue

        events_str   = _trigger_events_str(trigger)
        fields_found = _find_fields_in_apex(body, field_api_names)

        for field in fields_found:
            info = field_info[field]
            info["trigger_names"].append(name)

            is_written = _field_is_written_in_apex(body, field)
            if is_written:
                info["is_set"] = True
                action = "writes"
            else:
                action = "reads"

            info["criteria_notes"].append(f"{name} ({events_str}) — {action} field")

    return dict(field_info)


