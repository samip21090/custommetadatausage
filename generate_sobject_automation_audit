def _flow_involves_obj(metadata):
    if not metadata:
        return False
    start = metadata.get("start") or {}
    if start.get("object") == OBJECT_NAME:
        return True
    for key in ("recordLookups", "recordUpdates", "recordCreates", "recordDeletes"):
        for op in _safe_list(metadata.get(key)):
            if op.get("object") == OBJECT_NAME:
                return True
    return False


def _flow_entry_conditions_str(metadata):
    start   = metadata.get("start") or {}
    filters = _safe_list(start.get("filters"))

    if not filters:
        trigger_type   = start.get("triggerType", "")
        record_trigger = start.get("recordTriggerType", "")
        parts = []
        if trigger_type:
            parts.append(f"Trigger: {trigger_type}")
        if record_trigger:
            parts.append(f"On: {record_trigger}")
        return "; ".join(parts)

    parts = []
    for f in filters:
        field    = f.get("field", "")
        operator = OPERATOR_MAP.get(f.get("operator", ""), f.get("operator", ""))
        val      = f.get("value") or {}
        if isinstance(val, dict):
            value = (
                val.get("stringValue")
                or val.get("numberValue")
                or val.get("booleanValue")
                or val.get("elementReference")
                or ""
            )
        else:
            value = str(val)
        parts.append(f"{field} {operator} '{value}'" if value else f"{field} {operator}")

    logic  = start.get("filterLogic", "")
    result = " | ".join(parts)
    if logic and logic not in ("AND", ""):
        result = f"Logic: {logic} | " + result
    return result


def _find_fields_in_flow_metadata(metadata, field_api_names):
    """
    Returns dict: field_api_name -> {is_read: bool, is_written: bool}
    """
    field_names_lower = {f.lower(): f for f in field_api_names}
    result = defaultdict(lambda: {"is_read": False, "is_written": False})

    # Entry criteria filters
    start = metadata.get("start") or {}
    for flt in _safe_list(start.get("filters")):
        field = (flt.get("field") or "").lower()
        if field in field_names_lower:
            result[field_names_lower[field]]["is_read"] = True

    # Record Lookups (reads)
    for rl in _safe_list(metadata.get("recordLookups")):
        if rl.get("object") != OBJECT_NAME:
            continue
        for f in _safe_list(rl.get("queriedFields")):
            fl = (f or "").lower()
            if fl in field_names_lower:
                result[field_names_lower[fl]]["is_read"] = True
        for oa in _safe_list(rl.get("outputAssignments")):
            fl = (oa.get("field") or "").lower()
            if fl in field_names_lower:
                result[field_names_lower[fl]]["is_read"] = True

    # Record Updates + Creates (writes)
    for op_list in [
        _safe_list(metadata.get("recordUpdates")),
        _safe_list(metadata.get("recordCreates")),
    ]:
        for op in op_list:
            if op.get("object") != OBJECT_NAME:
                continue
            for ia in _safe_list(op.get("inputAssignments")):
                fl = (ia.get("field") or "").lower()
                if fl in field_names_lower:
                    result[field_names_lower[fl]]["is_written"] = True

    # Decision conditions (reads in if/else logic)
    for dec in _safe_list(metadata.get("decisions")):
        for rule in _safe_list(dec.get("rules")):
            for cond in _safe_list(rule.get("conditions")):
                lv = cond.get("leftValueReference") or ""
                for field in field_api_names:
                    if field.lower() in lv.lower():
                        result[field]["is_read"] = True

    return dict(result)


def analyze_flows(field_api_names, token, inst_url):
    """
    Returns dict: field_api_name -> {
        flow_names: [str],
        entry_conditions: [str],
        criteria_notes: [str],
        is_set: bool,
    }
    """
    all_flows = fetch_all_active_flows()

    field_info = defaultdict(lambda: {
        "flow_names":       [],
        "entry_conditions": [],
        "criteria_notes":   [],
        "is_set":           False,
    })

    relevant_count = 0
    total_flows    = len(all_flows)

    for i, flow in enumerate(all_flows, 1):
        flow_id    = flow["Id"]
        flow_label = flow.get("MasterLabel", flow_id)

        if i % 50 == 0:
            print(f"    Flow scan: {i}/{total_flows} checked, {relevant_count} relevant so far")

        metadata = fetch_flow_metadata(flow_id, token, inst_url)
        if not metadata:
            continue

        if not _flow_involves_obj(metadata):
            continue

        relevant_count += 1
        field_usage  = _find_fields_in_flow_metadata(metadata, field_api_names)
        entry_conds  = _flow_entry_conditions_str(metadata)

        for field, usage in field_usage.items():
            if not (usage["is_read"] or usage["is_written"]):
                continue

            info = field_info[field]
            info["flow_names"].append(flow_label)
            info["entry_conditions"].append(entry_conds)

            if usage["is_written"]:
                info["is_set"] = True
                action = "set by flow"
            else:
                action = "read by flow"

            note = f"{flow_label} ({action})"
            if entry_conds:
                note += f" | Entry: {entry_conds}"
            info["criteria_notes"].append(note)

    print(f"    Flows relevant to {OBJECT_NAME}: {relevant_count} of {total_flows}")
    return dict(field_info)


