def _yesno(val):
    return "Y" if val else "N"


def build_rows(merged_fields, trigger_analysis, apex_class_analysis, flow_analysis, vr_analysis, wf_analysis):
    rows = []

    for api_name, meta in sorted(
        merged_fields.items(),
        key=lambda x: (x[1].get("label") or x[0]).lower(),
    ):
        trig  = trigger_analysis.get(api_name, {})
        cls   = apex_class_analysis.get(api_name, {})
        flow  = flow_analysis.get(api_name, {})
        vr    = vr_analysis.get(api_name, {})
        wf    = wf_analysis.get(api_name, {})

        # Trigger
        trig_names    = trig.get("trigger_names", [])
        trig_notes    = trig.get("criteria_notes", [])
        trig_is_set   = trig.get("is_set", False)

        # Apex Class
        cls_names     = cls.get("class_names", [])
        cls_notes     = cls.get("criteria_notes", [])
        cls_is_set    = cls.get("is_set", False)

        # Flow
        flow_names    = flow.get("flow_names", [])
        flow_notes    = flow.get("criteria_notes", [])
        flow_is_set   = flow.get("is_set", False)

        # Validation Rule
        vr_names      = vr.get("vr_names", [])
        vr_formulas   = vr.get("vr_formulas", [])

        # Workflow
        wf_names      = wf.get("wf_names", [])
        wf_is_set     = wf.get("is_set", False)

        # Is Set by Automation
        set_by = []
        if trig_is_set:
            for n in trig_names:
                set_by.append(f"{n} (Apex Trigger)")
        if cls_is_set:
            for n in cls_names:
                set_by.append(f"{n} (Apex Class)")
        if flow_is_set:
            for n in flow_names:
                set_by.append(f"{n} (Flow)")
        if wf_is_set:
            for n in wf_names:
                set_by.append(f"{n} (Workflow Field Update)")
        is_set_str = f"Y — {'; '.join(set_by)}" if set_by else "N"

        rows.append({
            "Field Label":                      meta["label"],
            "Field API Name":                   api_name,
            "Data Type":                        meta["dataType"],
            "Field Values":                     meta["fieldValues"],
            "Behavior":                         meta["behavior"],
            "Standard or Custom":               "Custom" if meta["isCustom"] else "Standard",
            "Has Default Value":                "Yes" if meta["hasDefault"] else "No",
            "Is Formula Field":                 "Yes" if meta["isFormula"] else "No",
            "Is Encrypted":                     "Yes" if meta["isEncrypted"] else "No",
            "Available for Reporting":          "Yes" if meta["isReportable"] else "No",
            "Population Rate":                  meta["popRate"],
            "Field Created Date":               meta["createdDate"],
            "Field Last Modified Date":         meta["modifiedDate"],
            "Workflow Rule Dependencies":       "; ".join(wf_names),
            "Is used in Trigger (Y/N)":         _yesno(trig_names),
            "Trigger Name":                     "; ".join(trig_names),
            "Trigger Logic / Criteria":         "\n".join(trig_notes),
            "Is used in Apex Class (Y/N)":      _yesno(cls_names),
            "Apex Class Name":                  "; ".join(cls_names),
            "Apex Class Logic / Notes":         "\n".join(cls_notes),
            "Is used in Flow (Y/N)":            _yesno(flow_names),
            "Flow Name":                        "; ".join(flow_names),
            "Flow Criteria / Entry Conditions": "\n".join(flow_notes),
            "Is used in Validation Rule (Y/N)": _yesno(vr_names),
            "Validation Rule Name":             "; ".join(vr_names),
            "Validation Logic":                 "\n".join(vr_formulas),
            "Is Set by Automation (Y/N)":       is_set_str,
        })

    return rows


# ─────────────────────────────────────────────────────────────────────────────
# SECTION 8 — EXCEL WRITER
# ─────────────────────────────────────────────────────────────────────────────

WIDE_COLS = {
    "Field Values",
    "Trigger Logic / Criteria",
    "Apex Class Logic / Notes",
    "Flow Criteria / Entry Conditions",
    "Validation Logic",
    "Is Set by Automation (Y/N)",
    "Workflow Rule Dependencies",
}


def write_excel(rows):
    wb = Workbook()
    ws = wb.active
    ws.title = OBJECT_NAME[:31]

    # Header row
    ws.append(HEADERS)
    for col_idx in range(1, len(HEADERS) + 1):
        cell           = ws.cell(row=1, column=col_idx)
        cell.fill      = HEADER_FILL
        cell.font      = HEADER_FONT
        cell.alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)
    ws.row_dimensions[1].height = 30

    # Data rows
    for row_idx, row in enumerate(rows, start=2):
        fill = ALT_FILL if row_idx % 2 == 0 else None
        for col_idx, header in enumerate(HEADERS, start=1):
            val  = row.get(header, "") or ""
            cell = ws.cell(row=row_idx, column=col_idx, value=val)
            cell.alignment = Alignment(vertical="top", wrap_text=True)
            if fill:
                cell.fill = fill

    # Column widths
    for col_idx, header in enumerate(HEADERS, start=1):
        if header in WIDE_COLS:
            ws.column_dimensions[get_column_letter(col_idx)].width = 55
        else:
            max_len = len(header)
            for row in rows:
                val        = str(row.get(header, "") or "")
                first_line = val.split("\n")[0]
                max_len    = max(max_len, min(len(first_line), 60))
            ws.column_dimensions[get_column_letter(col_idx)].width = min(max_len + 4, 50)

    ws.freeze_panes = "A2"
    ws.auto_filter.ref = ws.dimensions

    out_dir = os.path.dirname(OUTPUT_XLSX)
    if out_dir:
        os.makedirs(out_dir, exist_ok=True)
    wb.save(OUTPUT_XLSX)
    print(f"\nExcel saved: {OUTPUT_XLSX}")


