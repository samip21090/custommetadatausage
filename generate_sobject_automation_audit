def fetch_workflow_dependencies():
    cached = load_cache(CACHE_DIR, f"wf_{OBJECT_NAME}")
    if cached is not None:
        return cached

    print(f"  [fetch] Workflow field updates for {OBJECT_NAME} ...")

    records = run_soql(
        f"SELECT Id, Name, TableEnumOrId, FieldApiName, Formula "
        f"FROM WorkflowFieldUpdate "
        f"WHERE TableEnumOrId = '{OBJECT_NAME}' "
        f"LIMIT 500",
        org_alias=ORG_ALIAS,
        tooling=True,
    )

    if not records and OBJECT_NAME.endswith("__c"):
        entity_id = fetch_entity_id()
        if entity_id:
            records = run_soql(
                f"SELECT Id, Name, TableEnumOrId, FieldApiName, Formula "
                f"FROM WorkflowFieldUpdate "
                f"WHERE TableEnumOrId = '{entity_id}' "
                f"LIMIT 500",
                org_alias=ORG_ALIAS,
                tooling=True,
            )

    print(f"         {len(records)} workflow field updates")

    result = defaultdict(lambda: {"wf_names": [], "is_set": False})
    for r in records:
        field = r.get("FieldApiName", "")
        name  = r.get("Name", "")
        if field:
            result[field]["wf_names"].append(name)
            result[field]["is_set"] = True

    final = {k: dict(v) for k, v in result.items()}
    save_cache(CACHE_DIR, f"wf_{OBJECT_NAME}", final)
    return final


